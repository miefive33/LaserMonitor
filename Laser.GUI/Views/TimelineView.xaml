<UserControl x:Class="Laser.GUI.Views.TimelineView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Style="{StaticResource CardStyle}">
        <StackPanel>

            <!-- タイトル -->
            <TextBlock Text="稼働状況"
                       Style="{StaticResource TitleText}"/>

            <!-- 時間軸 -->
            <UniformGrid Columns="12" Margin="0,5">
                <TextBlock Text="8" Foreground="Gray"/>
                <TextBlock Text="9" Foreground="Gray"/>
                <TextBlock Text="10" Foreground="Gray"/>
                <TextBlock Text="11" Foreground="Gray"/>
                <TextBlock Text="12" Foreground="Gray"/>
                <TextBlock Text="13" Foreground="Gray"/>
                <TextBlock Text="14" Foreground="Gray"/>
                <TextBlock Text="15" Foreground="Gray"/>
                <TextBlock Text="16" Foreground="Gray"/>
                <TextBlock Text="17" Foreground="Gray"/>
                <TextBlock Text="18" Foreground="Gray"/>
                <TextBlock Text="19" Foreground="Gray"/>
            </UniformGrid>

            <!-- Sheet A -->
            <Grid Height="30" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Sheet A123"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Grid Grid.Column="1">

                    <!-- Cutting -->
                    <Border Background="LimeGreen"
                            Width="250"
                            HorizontalAlignment="Left"/>

                    <!-- Setup -->
                    <Border Background="DodgerBlue"
                            Width="80"
                            Margin="250,0,0,0"/>

                    <!-- Error -->
                    <Border Background="Red"
                            Width="120"
                            Margin="330,0,0,0"/>

                </Grid>
            </Grid>

            <!-- Sheet B -->
            <Grid Height="30" Margin="0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Sheet B204"
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <Grid Grid.Column="1">

                    <Border Background="LimeGreen"
                            Width="200"
                            Margin="50,0,0,0"/>

                    <Border Background="Purple"
                            Width="100"
                            Margin="260,0,0,0"/>

                    <Border Background="Red"
                            Width="150"
                            Margin="380,0,0,0"/>

                </Grid>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>