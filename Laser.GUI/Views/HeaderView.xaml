<UserControl x:Class="Laser.GUI.Views.HeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:Laser.GUI.Converters"
             DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">

    <UserControl.Resources>
        <conv:ReferenceEqualsMultiConverter x:Key="RefEqualsConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <DockPanel>

            <!-- 左：タイトル -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock Text="システム稼働実績"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           Margin="10,0"/>

                <!-- ★ ADDED -->
                <ItemsControl ItemsSource="{Binding Machines}"
                              Margin="12,0,0,0">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    Margin="0,0,6,0"
                                    Padding="12,4"
                                    Command="{Binding DataContext.SelectMachineCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Background" Value="#2B2B2B"/>
                                        <Setter Property="Foreground" Value="White"/>
                                        <Setter Property="BorderBrush" Value="#666666"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Style.Triggers>
                                            <DataTrigger Value="True">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource RefEqualsConverter}">
                                                        <Binding/>
                                                        <Binding Path="DataContext.SelectedMachine"
                                                                 RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="Background" Value="#7CFC00"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                                <Setter Property="BorderBrush" Value="#7CFC00"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- 左矢印 -->
                <Button Content="◀" Width="30" Margin="5"
                    Click="PrevDate_Click"/>

                <!-- 日付 -->
                <TextBlock x:Name="DateText"
                   Text="2026年3月24日"
                   Foreground="Orange"
                   FontSize="16"
                   VerticalAlignment="Center"
                   Margin="10,0"/>

                <!-- 右矢印 -->
                <Button Content="▶" Width="30" Margin="5"
                    Click="NextDate_Click"/>

                <!-- カレンダー -->
                <DatePicker x:Name="DatePicker"
                            Width="135"
                            Margin="10,0,5,0"
                            SelectedDateChanged="DatePicker_SelectedDateChanged"/>

            </StackPanel>

            <!-- 右：操作エリア -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right"
                        Margin="10,0">

                <!-- 👇 ファイルパス -->
                <TextBox x:Name="FilePathTextBox"
                         Width="250"
                         Height="28"
                         Margin="5"
                         VerticalContentAlignment="Center"
                         Text="C:\logs\laser.log"/>

                <!-- 👇 差分更新 -->
                <Button Content="更新"
                        Width="80"
                        Margin="5"
                        Click="UpdateClicked"/>

                <!-- 👇 全再取込 -->
                <Button Content="全再取込"
                        Width="100"
                        Margin="5"
                        Click="ReloadClicked"/>

            </StackPanel>

        </DockPanel>
    </Grid>
</UserControl>