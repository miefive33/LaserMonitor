<UserControl x:Class="Laser.GUI.Views.HeaderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <DockPanel>

            <!-- 左：タイトル -->
            <TextBlock Text="システム稼働実績"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       DockPanel.Dock="Left"
                       Margin="10,0"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- 左矢印 -->
                <Button Content="◀" Width="30" Margin="5"
                    Click="PrevDate_Click"/>

                <!-- 日付 -->
                <TextBlock x:Name="DateText"
                   Text="2026年3月24日"
                   Foreground="Orange"
                   FontSize="16"
                   VerticalAlignment="Center"
                   Margin="10,0"/>

                <!-- 右矢印 -->
                <Button Content="▶" Width="30" Margin="5"
                    Click="NextDate_Click"/>

            </StackPanel>

            <!-- 右：操作エリア -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        DockPanel.Dock="Right"
                        Margin="10,0">

                <!-- 👇 ファイルパス -->
                <TextBox x:Name="FilePathTextBox"
                         Width="250"
                         Height="28"
                         Margin="5"
                         VerticalContentAlignment="Center"
                         Text="C:\logs\laser.log"/>

                <!-- 👇 差分更新 -->
                <Button Content="更新"
                        Width="80"
                        Margin="5"
                        Click="UpdateClicked"/>

                <!-- 👇 全再取込 -->
                <Button Content="全再取込"
                        Width="100"
                        Margin="5"
                        Click="ReloadClicked"/>

            </StackPanel>

        </DockPanel>
    </Grid>
</UserControl>