<UserControl x:Class="Laser.GUI.Views.KpiPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:oxy="http://oxyplot.org/wpf">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Style="{StaticResource CardStyle}" Grid.Column="0">
            <StackPanel>
                <TextBlock Text="本日のサマリー" Style="{StaticResource TitleText}"/>
                <oxy:PlotView Model="{Binding PieModel}"
                  Width="180"
                  Height="180"
                  Background="Transparent"/>
                <TextBlock Text="{Binding KpiSummary.OperationRate, StringFormat=稼働率 {0:0.0}%}" Style="{StaticResource ValueText}"/>

            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}" Grid.Column="1">
            <StackPanel>
                <TextBlock Text="ロス分析" Style="{StaticResource TitleText}"/>
                <TextBlock Text="待機ロス 2.3h" Foreground="White"/>
                <TextBlock Text="段取りロス 2.3h" Foreground="White"/>
                <TextBlock Text="エラーロス 1.1h" Foreground="White"/>
            </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}" Grid.Column="2">
            <StackPanel>
                <TextBlock Text="ボトルネック" Style="{StaticResource TitleText}"/>
                <TextBlock Text="1位 エラー 45分" Foreground="White"/>
                <TextBlock Text="2位 待機 22分" Foreground="White"/>
                <TextBlock Text="3位 段取り 15分" Foreground="White"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>