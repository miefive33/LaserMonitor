<Window x:Class="Laser.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Laser.GUI.Views"
        Title="Laser Dashboard"
        Width="1400"
        Height="900"
        Background="#0F172A">

    <Grid Margin="20">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Header -->
            <RowDefinition Height="Auto"/>
            <!-- KPI -->
            <RowDefinition Height="2*"/>
            <!-- Timeline（縮める） -->
            <RowDefinition Height="1.5*"/>
            <!-- Bottom（広げる） -->
        </Grid.RowDefinitions>

        <views:HeaderView Grid.Row="0" x:Name="HeaderView"/>
        <views:KpiPanelView Grid.Row="1" Margin="0,20,0,20"/>
        <views:TimelineView Grid.Row="2" Margin="0,0,0,20"/>
        <views:BottomPanelView Grid.Row="3"/>

    </Grid>
</Window>